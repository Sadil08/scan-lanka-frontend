# Public (browser-exposed) config only. Real secrets are server-only / in a secret manager (global/02 §5).
# Every variable the frontend reads is listed here (P2-6). NEXT_PUBLIC_* values are inlined into the
# client bundle at build time, so they must never hold secrets.

# Base URL of the backend API (used for fetches and the CSP connect-src / report-uri).
NEXT_PUBLIC_API_BASE=http://localhost:8080

# Public origin of this site (canonical URLs, sitemap, absolute links).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Captcha site token sent with abuse-prone forms (contact / quote). Dev bypass token by default.
NEXT_PUBLIC_CAPTCHA_TOKEN=test-captcha-bypass

# Switch CSP from report-only to enforced. Leave unset in dev; set true in prod after the
# report-only soak (global/02 §7).
# CSP_ENFORCE=true
